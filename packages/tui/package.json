{
  "name": "@mmbridge/tui",
  "version": "0.7.2",
  "description": "Terminal UI rendering for the mmbridge control plane",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mmbridge/adapters": "workspace:*",
    "@mmbridge/core": "workspace:*",
    "@mmbridge/session-store": "workspace:*",
    "ink": "^5",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18"
  },
  "devDependencies": {
    "@types/react": "^18"
  }
}
