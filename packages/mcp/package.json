{
  "name": "@mmbridge/mcp",
  "version": "0.7.2",
  "description": "MCP server exposing mmbridge control-plane tools",
  "type": "module",
  "bin": {
    "mmbridge-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mmbridge/core": "workspace:*",
    "@mmbridge/adapters": "workspace:*",
    "@mmbridge/context-broker": "workspace:*",
    "@mmbridge/session-store": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
