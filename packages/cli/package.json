{
  "name": "@mmbridge/cli",
  "version": "0.6.1",
  "type": "module",
  "bin": {
    "mmbridge": "dist/bin/mmbridge.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mmbridge/adapters": "workspace:*",
    "@mmbridge/core": "workspace:*",
    "@mmbridge/integrations": "workspace:*",
    "@mmbridge/session-store": "workspace:*",
    "@mmbridge/tui": "workspace:*",
    "@clack/prompts": "^1.1.0",
    "commander": "^13.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
