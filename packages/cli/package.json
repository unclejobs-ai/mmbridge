{
  "name": "@mmbridge/cli",
  "version": "0.7.0",
  "description": "Command-line control plane for multi-model review and coordination",
  "type": "module",
  "bin": {
    "mmbridge": "dist/bin/mmbridge.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./repl-router": {
      "import": "./dist/commands/repl-router.js",
      "types": "./dist/commands/repl-router.d.ts"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mmbridge/adapters": "workspace:*",
    "@mmbridge/context-broker": "workspace:*",
    "@mmbridge/core": "workspace:*",
    "@mmbridge/integrations": "workspace:*",
    "@mmbridge/session-store": "workspace:*",
    "@mmbridge/tui": "workspace:*",
    "@clack/prompts": "^1.1.0",
    "commander": "^13.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
